# Twelve Data free tier (https://twelvedata.com) — production live prices.
# Without it the site falls back to Yahoo's quote endpoint, then to the
# committed daily baseline. 28 tickers x 26 market-hour windows = 728/800
# credits/day, enforced by market-hours gating in lib/sources/live.ts.
TWELVEDATA_API_KEY=

# Kill switch for the unofficial Forbes feed (set to 0 to serve the daily
# baseline net worths instead).
FORBES_ENABLED=1

# Canonical URL, used by sitemap.xml / robots.txt / OG metadata.
NEXT_PUBLIC_SITE_URL=https://example.com
